generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int        @id @default(autoincrement())
  createdAt DateTime   @default(now())
  email     String     @unique
  password  String
  bookmarks Bookmark[]
}

model Bookmark {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  url         String
  title       String?
  description String?
  imageUrl    String?
  tags        String[]
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

